# qdyn.yaml.example — QDYN configuration template
# Copy to config/qdyn.yaml and modify as needed.
#
# Config format: "worker pool" — each pool has two sub-sections:
#   'pool'   — pool-level parameters (size, polling, work directory)
#   'worker' — per-worker execution environment and jf-remote settings
# Workers are auto-generated as {pool_name}_{NNN} in the jf config.
# Use scripts/generate_jf_config.py to produce the jf project YAML.

basic:
  jf_project_path: "config/jf_qdyn.yaml"
  jf_project_name: "jf_qdyn"
  jf_config_hash: ""  # managed by scripts/generate_jf_config.py
  user_db_path: "data/qdyn_users.db"
  mongo_dir: "mongo/"
  port: 8000

# Active pool (must match a key in 'worker_pools' below)
active_pool: local_slurm

# Worker pool definitions.
# Each pool generates N workers named {pool_name}_{NNN} in the jf config.
# 'pool' contains pool-level parameters (size, polling interval, work dir).
# 'worker' contains per-worker settings: jf-remote fields (type, scheduler_type,
# resources, max_jobs) plus QDYN execution environment (partition, modules, etc.).
worker_pools:
  local_slurm:
    pool:
      size: 30
      queue_poll_interval: 60    # seconds between queue polling rounds
      work_dir_base: /absolute/path/to/runs
      user_data: /absolute/path/to/user_data  # shared by all workers in this pool
    worker:
      type: local                # jf-remote worker type
      scheduler_type: slurm      # jf-remote scheduler type
      max_jobs: 20
      resources:
        partition: chu
        time: "48:00:00"
        # worker.resources keeps only nodes/processes_per_node/threads_per_process
        # as portable top-level fields; all other keys pass through unchanged
        # via QResources.scheduler_kwargs.
      gpu_resources: null
        # Required. Set to null on non-GPU clusters.
        # For GPU-capable clusters, provide a mapping similar to resources
        # (for example partition/account/gres or other scheduler fields).

      # QDYN specific worker configs
      # Don't remove any following entries.
      cpus_per_node: 96
      modules:
        vasp: ['compiler/oneAPI/2023.2.0', 'vasp/6.5.1']
        python: []
        namd: ['compiler/oneAPI/2023.2.0']
      export:
        vasp:
          PYTHONPATH: '/absolute/path/to/qdyn/src:$PYTHONPATH'
        python:
          PYTHONPATH: '/absolute/path/to/qdyn/src:$PYTHONPATH'
        namd:
          PYTHONPATH: '/absolute/path/to/qdyn/src:$PYTHONPATH'
          PATH: '/absolute/path/to/Hefei-NAMD-DEV-2025.01:$PATH'
      pre_run:
        vasp: 'source /absolute/path/to/qdyn/.venv/bin/activate'
        python: 'source /absolute/path/to/qdyn/.venv/bin/activate'
        namd: 'source /absolute/path/to/qdyn/.venv/bin/activate'
      installed:
        vasp: true
        vasp_ae: true
        abacus: false
        python: true
        namd: true
      pp_path:
        vasp: '/absolute/path/to/vasp-pp'
      orb_path:
        vasp: ''
      nvt:
        vasp: { nodes: 1, processes_per_node: 96, threads_per_process: 1 }
      nve:
        vasp: { nodes: 1, processes_per_node: 96, threads_per_process: 1 }
      scf:
        vasp: { nodes: 1, processes_per_node: 96, threads_per_process: 1 }
      # nvt/nve/scf must use portable resource keys above. They override
      # same-meaning values from worker.resources during dispatch.

auth:
  secret_key: ""  # leave empty to auto-generate on first start
  token_expire_hours: 24
